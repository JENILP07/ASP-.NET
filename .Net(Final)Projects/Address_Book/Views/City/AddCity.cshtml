<main id="main" class="main">

    <div class="pagetitle">
        <h1>Add City</h1>
        <nav>
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
                <li class="breadcrumb-item">City</li>
                <li class="breadcrumb-item active">Add City</li>
            </ol>
        </nav>
    </div><!-- End Page Title -->
   
    @model CityModel

    @using (Html.BeginForm("SaveCity", "City", FormMethod.Post))
    {
        @Html.AntiForgeryToken()

        <section class="section">
            <div class="col-lg-12">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Create City <hr /></h5>

                        <div class="row mb-3">
                            <div class="col-sm-1"></div>
                            <label for="StateID" class="col-sm-2 col-form-label"><span class="text-danger">*</span> State</label>
                            <div class="col-sm-6">
                                @Html.TextBoxFor(model => model.StateID, new { @class = "form-control", type = "number", required = "required", placeholder = "Enter Country ID" })
                                @Html.ValidationMessageFor(model => model.StateID, "", new { @class = "text-danger" })
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-sm-1"></div>
                            <label for="CityName" class="col-sm-2 col-form-label"><span class="text-danger">*</span> City Name</label>
                            <div class="col-sm-6">
                                @Html.TextBoxFor(model => model.CityName, new { @class = "form-control", required = "required", placeholder = "Enter City Name" })
                                @Html.ValidationMessageFor(model => model.CityName, "", new { @class = "text-danger" })
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-sm-1"></div>
                            <label for="STDCode" class="col-sm-2 col-form-label">STD Code</label>
                            <div class="col-sm-6">
                                @Html.TextBoxFor(model => model.STDCode, new { @class = "form-control", placeholder = "Enter STD Code (Optional)" })
                                @Html.ValidationMessageFor(model => model.STDCode, "", new { @class = "text-danger" })
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-sm-1"></div>
                            <label for="PinCode" class="col-sm-2 col-form-label">Pin Code</label>
                            <div class="col-sm-6">
                                @Html.TextBoxFor(model => model.PinCode, new { @class = "form-control", placeholder = "Enter Pin Code (Optional)", maxlength = "6" })
                                @Html.ValidationMessageFor(model => model.PinCode, "", new { @class = "text-danger" })
                            </div>
                        </div>

                        @Html.HiddenFor(model => model.CreationDate, new { Value = DateTime.Now })

                        <div class="text-center">
                            <button type="submit" class="btn btn-primary me-3 mt-3">Submit</button>
                            <button type="reset" class="btn btn-secondary me-3 mt-3">Reset</button>
                            <a class="btn btn-danger mt-3" asp-controller="City" asp-action="CityList">Cancel</a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    }


</main><!-- End #main -->