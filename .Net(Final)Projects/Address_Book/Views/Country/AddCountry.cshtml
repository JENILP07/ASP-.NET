<main id="main" class="main">

    <div class="pagetitle">
        <h1>Add Country</h1>
        <nav>
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
                <li class="breadcrumb-item">Country</li>
                <li class="breadcrumb-item active">Add Country</li>
            </ol>
        </nav>
    </div><!-- End Page Title -->
    
    @model CountryModel

    @using (Html.BeginForm("CountryAdd", "Country", FormMethod.Post))
    {
        @Html.AntiForgeryToken()

        <section class="section">
            <div class="col-lg-12">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Create Country <hr /></h5>

                        <div class="row mb-3">
                            <div class="col-sm-1"></div>
                            <label for="CountryName" class="col-sm-2 col-form-label"><span class="text-danger">*</span> Country Name</label>
                            <div class="col-sm-6">
                                @Html.TextBoxFor(model => model.CountryName, new { @class = "form-control", required = "required", placeholder = "Enter Country Name" })
                                @Html.ValidationMessageFor(model => model.CountryName, "", new { @class = "text-danger" })
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-sm-1"></div>
                            <label for="CountryCode" class="col-sm-2 col-form-label"><span class="text-danger">*</span> Country Code</label>
                            <div class="col-sm-6">
                                @Html.TextBoxFor(model => model.CountryCode, new { @class = "form-control", required = "required", placeholder = "Enter Country Code" })
                                @Html.ValidationMessageFor(model => model.CountryCode, "", new { @class = "text-danger" })
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-sm-1"></div>
                            <label for="UserID" class="col-sm-2 col-form-label"><span class="text-danger">*</span> UserID</label>
                            <div class="col-sm-6">
                                @Html.TextBoxFor(model => model.UserID, new { @class = "form-control", required = "required", placeholder = "Enter UserID" })
                                @Html.ValidationMessageFor(model => model.UserID, "", new { @class = "text-danger" })
                            </div>
                        </div>


                        <div class="text-center">
                            <button 
                                type="submit" class="btn btn-primary me-3 mt-3">Submit</button>
                            <button type="reset" class="btn btn-secondary me-3 mt-3">Reset</button>
                            <a class="btn btn-danger mt-3" asp-controller="Country" asp-action="CountryList">Cancel</a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    }


</main><!-- End #main -->