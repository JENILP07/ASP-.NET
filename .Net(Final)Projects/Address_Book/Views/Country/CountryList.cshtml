@model DataTable
@using System.Data

<main id="main" class="main">

    <div class="pagetitle">
        <h1>Country List</h1>
        <nav>
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
                <li class="breadcrumb-item">Country</li>
                <li class="breadcrumb-item active">Country List</li>
            </ol>
        </nav>
    </div><!-- End Page Title -->

    <div> <span class="text-danger">@TempData["ErrorMessage"]</span>HELLO</div>
    <section class="section">
        <div class="row">
            <div class="col-lg-12">
               

                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Country List</h5>

                        <!-- Style for Add button -->
                        <link rel="stylesheet" href="~/assets/Extra/AddButton.css" />
                        <!--End Style -->
                        <a asp-controller="Country" asp-action="AddCountry">
                            <button style="float:right; height:35px; margin-right:10px">
                                Add Country
                                <div class="arrow-wrapper">
                                    <div class="arrow"></div>
                                </div>
                            </button>
                        </a><!--End Button -->
                        <br /><br />

                        <!-- Table with stripped rows -->
                        <table class="table">
                            <thead>
                                <tr>

                                    <th>CountryName</th>
                                    <th>CountryCode</th>
                                    <th>Delete</th>
                                    <th>Edit</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (DataRow datarow in Model.Rows)
                                {
                                    <tr>

                              
                                        <td>@datarow["CountryName"]</td>
                                        <td>@datarow["CountryCode"]</td>


                                        <td>
                                            <form method="post" asp-controller="Country" asp-action="CountryDelete">
                                                <input type="hidden" name="CountryID" value="@datarow["CountryID"]" />
                                                <button type="submit" onclick=" alrt()" class="btn btn-outline-danger btn-xs">
                                                    <i class="bi bi-x"></i>
                                                </button>
                                            </form>

                                        </td>

                                        <td>
                                            <button>
                                                <a asp-controller="Country" asp-action="CountryForm" asp-route-CountryID="@datarow["CountryID"]" class="btn btn-primary btn-sm" style="padding: 2px 6px; font-size: 12px;">
                                                    <i class="fa fa-pencil"></i>
                                                </a>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        <!-- End Table with stripped rows -->

                    </div>
                </div>

            </div>
        </div>
    </section>
    <script>
        function alrt() {
            alert('Sure!')
        }
    </script>
</main><!-- End #main -->
