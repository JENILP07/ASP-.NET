@model StateModel

<main id="main" class="main">

    <div class="pagetitle">
        <h1>StateUser</h1>
        <nav>
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
                <li class="breadcrumb-item">State</li>
                <li class="breadcrumb-item">Add State</li>
                <li class="breadcrumb-item active">StateUser</li>
            </ol>
        </nav>
    </div><!-- End Page Title -->

    <div>
        <span class="text-danger">@TempData["ErrorMessage"]</span>
    </div>

    <section class="section">
        <div class="row">
            <div class="col-lg-12">

                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Save State</h5>

                        <!-- Style for Add button -->
                        <link rel="stylesheet" href="~/assets/Extra/AddButton.css" />
                        <!--End Style -->
                        <a asp-controller="State" asp-action="StateUser">
                            <button style="float:right; height:35px; margin-right:10px">
                                Back
                                <div class="arrow-wrapper">
                                    <div class="arrow"></div>
                                </div>
                            </button>
                        </a><!--End Button -->
                        <br /><br />


                        <!-- Table with stripped rows -->
                        <table class="table datatable table-hover table-striped">
                            <thead>
                                <tr>
                                    <th>StateName</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <th>@Model.StateName</th>
                                </tr>
                            </tbody>
                        </table>
                        <!-- End Table with stripped rows -->

                    </div>
                </div>

            </div>
        </div>
    </section>

</main><!-- End #main -->