@model DataTable
@using System.Data
@{
    ViewData["Title"] = "Question List";
}

<main id="main" class="main">
    <div class="pagetitle">
        <h1>@ViewData["Title"]</h1>
        <nav>
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home">Dashboard</a></li>
                <li class="breadcrumb-item active">Question List</li>
            </ol>
        </nav>
    </div><!-- End Page Title -->
    <section class="section">
        <div class="row">
            <div class="card">
                <div class="card-body">
                    <h1 class="card-title"><i class="bx bx-search-alt"></i> Search Question</h1>

                    <!-- Search Form & Add Question Button -->
                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start gap-3 mb-4">
                        <!-- Search Form -->
                        <form method="get" class="flex-grow-1 w-100">
                            <div class="input-group">
                                <input type="search"
                                       class="form-control"
                                       placeholder="Search Question"
                                       aria-label="Search Question"
                                       name="searchTerm">
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-search"></i>
                                    <span class="d-none d-md-inline">Search</span>
                                </button>
                                <button type="reset" class="btn btn-outline-secondary">
                                    <i class="bi bi-arrow-counterclockwise"></i>
                                    <span class="d-none d-md-inline">Reset</span>
                                </button>
                            </div>
                        </form>
                        <div class="mt-3 mt-md-0 w-100 w-md-auto">
                            <a asp-controller="Question" asp-action="Form"
                               class="btn btn-success w-100 w-md-40"
                               id="addQuestion">
                                <i class="bi bi-plus-lg"></i>
                                <span class="d-none d-md-inline">Add Quiz (F9)</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>


    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-octagon me-1"></i>
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-1"></i>
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    <!-- Add Question Button below the search -->

    <section class="section">
        <div class="row">
            <div class="card">
                <div class="card-body">
                    <div class="row">
                        <div class="col-6">
                            <h2 class="card-title">Question List</h2>
                        </div>
                        <div class="col-6 text-end mt-4">
                            <a asp-controller="Question" asp-action="ExportToExcel" class="btn btn-outline-success">
                                <i class="bi bi-file-earmark-spreadsheet"></i> Export To Excel
                            </a>
                        </div>
                    </div>
                    @if (Model == null || Model.Rows.Count == 0)
                    {
                        <div class="alert alert-info">No question levels found.</div>
                    }
                    else
                    {
                        <div class="table-responsive ">
                            <table class="table datatable table-hover">
                                <thead>
                                    <tr>
                                       
                                        <th>Question Text</th>
                                        <th>Question Level</th>
                                        <th>Option A</th>
                                        <th>Option B</th>
                                        <th>Option C</th>
                                        <th>Option D</th>
                                        <th>Correct Option</th>
                                        <th>Question Marks</th>
                                        <th>isActive</th>
                                        <th>User Name</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <!-- Example row with responsive handling -->
                                    @foreach (DataRow dataRow in Model.Rows)
                                    {
                                        <tr>
                                            
                                            <td>@dataRow["QuestionText"]</td>
                                            <td>@dataRow["QuestionLevel"]</td>
                                            <td>@dataRow["OptionA"]</td>
                                            <td>@dataRow["OptionB"]</td>
                                            <td>@dataRow["OptionC"]</td>
                                            <td>@dataRow["OptionD"]</td>
                                            <td>@dataRow["CorrectOption"]</td>
                                            <td>@dataRow["QuestionMarks"]</td>
                                            <td>
                                                @if (Convert.ToBoolean(dataRow["IsActive"]))
                                                {
                                                    <span class="badge bg-success">Yes</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger">No</span>
                                                }
                                            </td>
                                            <td>@dataRow["Username"]</td>
                                            <td>
                                                <div class="d-flex gap-1">
                                                    <a asp-controller="Question" asp-action="Form"
                                                       asp-route-QuestionID="@dataRow["QuestionID"]"
                                                       class="btn btn-outline-primary btn-sm">
                                                        <i class="bi bi-pencil"></i>
                                                    </a>
                                                    <form asp-controller="Question" asp-action="Delete" method="post" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this question?');">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="QuestionID" value="@dataRow["QuestionID"]" />
                                                        <button type="submit" class="btn btn-outline-danger btn-sm">
                                                            <i class="bi bi-x"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                    <!-- More rows can be added here -->
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

        </div>
    </section>

    <script>
        document.addEventListener("keydown", function(event) {
            if (event.key === "F9") {
                event.preventDefault();
                let addQuestionButton = document.getElementById("addQuestion");
                if (addQuestionButton) {
                    addQuestionButton.click();
                }
            }
        });
    </script>
</main>
