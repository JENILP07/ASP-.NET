@model QuestionLevel
@{
    ViewData["Title"] = "Question Level Form";
}

<main id="main" class="main">
    <div class="pagetitle">
        <h1>Quiz Level Form</h1>
        <nav>
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home">Dashboard</a></li>
                <li class="breadcrumb-item"><a asp-controller="QuestionLevel" asp-action="Index">Question Level List</a></li>
                <li class="breadcrumb-item active">Question Level Form</li>
            </ol>
        </nav>
    </div>

    <section class="section">
        <div class="row">
            <div class="card">
                <div class="card-body">
                    <h1 class="card-title"><i class="ri-questionnaire-fill"></i> Add/Edit Quiz Level</h1>

                    <!-- 🔥 Validation Summary (Displays all errors at top) -->
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <!-- Quiz Level Form -->
                    <form asp-action="QuestionLevelAddEdit" asp-controller="QuestionLevel" method="post" class="row g-3">


                        <input type="hidden" asp-for="QuestionLevelID" />

                        <!-- Question Level Input -->
                        <div class="col-md-6">
                            <label asp-for="Level" class="form-label">Question Level <span class="text-danger">*</span></label>
                            <input asp-for="Level" class="form-control" />
                            <span asp-validation-for="Level" class="text-danger"></span> <!-- 🔥 Red error message -->
                        </div>

                        <!-- User Selection -->
                        <div class="col-md-6">
                            <label asp-for="UserID" class="form-label">Select User <span class="text-danger">*</span></label>
                            <select asp-for="UserID" class="form-control">
                                <option value="" disabled selected>-- Select User --</option>
                                @if (ViewBag.UserList != null)
                                {
                                    @foreach (var item in ViewBag.UserList)
                                    {
                                        <option value="@item.UserID" selected="@(item.UserID == Model.UserID ? "selected" : null)">
                                            @item.UserName
                                        </option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="UserID" class="text-danger"></span> <!-- Validation error message -->

                            <span asp-validation-for="UserID" class="text-danger"></span> <!-- 🔥 Red error message -->
                        </div>

                        <div class="col-12">
                            <div class="d-flex justify-content-between">
                                <div>
                                    <button type="submit" class="btn btn-primary">Submit</button>
                                    <button type="reset" class="btn btn-secondary">Reset</button>
                                </div>
                                <a asp-controller="QuestionLevel" asp-action="Index" class="btn btn-success align-self-end">
                                    Go Back
                                </a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </section>
</main>

