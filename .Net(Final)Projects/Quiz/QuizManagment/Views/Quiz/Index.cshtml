@model DataTable
@using System.Data

@{
    ViewData["Title"] = "Quiz List";
}
<!-- Table for Quiz List -->
<main id="main" class="main">
    <div class="pagetitle">
        <h1>Quiz List</h1>
        <nav>
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home">Dashboard</a></li>
                <li class="breadcrumb-item active">Quiz List</li>
            </ol>
        </nav>
    </div><!-- End Page Title -->
    <section class="section">
        <div class="row">
            <div class="card">
                <div class="card-body">
                    <h1 class="card-title"><i class="bx bx-search-alt"></i> Search Quiz</h1>

                    <!-- Search Form & Add Quiz Button -->
                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start gap-3 mb-4">
                        <!-- Search Form -->
                        <form method="get" class="flex-grow-1 w-100">
                            <div class="input-group">
                                <input type="search"
                                class="form-control"
                                placeholder="Search Quiz"
                                aria-label="Search Quiz"
                                name="searchTerm">
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-search"></i>
                                    <span class="d-none d-md-inline">Search</span>
                                </button>
                                <button type="reset" class="btn btn-outline-secondary">
                                    <i class="bi bi-arrow-counterclockwise"></i>
                                    <span class="d-none d-md-inline">Reset</span>
                                </button>
                            </div>
                        </form>

                        <!-- Add Quiz Button -->
                        <div class="mt-3 mt-md-0 w-100 w-md-auto">
                            <a asp-controller="Quiz" asp-action="Form"
                            class="btn btn-success w-100 w-md-40"
                            id="addQuiz">
                                <i class="bi bi-plus-lg"></i>
                                <span class="d-none d-md-inline">Add Quiz (F9)</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-octagon me-1"></i>
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-1"></i>
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    <section class="section">
        <div class="row">
            <div class="card">
                <div class="card-body">
                    <div class="row">
                        <div class="col-6">
                            <h2 class="card-title">Quiz List</h2>
                        </div>
                        <div class="col-6 text-end mt-4">
                            <a asp-controller="Quiz" asp-action="ExportToExcel" class="btn btn-outline-success">
                                <i class="bi bi-file-earmark-spreadsheet"></i> Export To Excel
                            </a>
                        </div>
                    </div>
                    @if (Model == null || Model.Rows.Count == 0)
                    {
                        <div class="alert alert-info">No Quiz found.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table datatable">
                                <thead>
                                    <tr>
                                        <th>Quiz ID</th>
                                        <th>Quiz Name</th>
                                        <th>Total Questions</th>
                                        <th>Quiz Date</th>
                                        <th>User Name</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (DataRow dataRow in Model.Rows)
                                    {
                                        <tr>
                                            <td>@dataRow["QuizID"]</td>
                                            <td>@dataRow["QuizName"]</td>
                                            <td>@dataRow["TotalQuestions"]</td>
                                            <td>@dataRow["QuizDate"]</td>
                                            <td>@dataRow["UserName"]</td>
                                            <td>
                                                <div class="d-flex gap-1">
                                                    <!-- Edit Button -->
                                                    <a asp-controller="Quiz" asp-action="Form"
                                                       asp-route-QuizID="@dataRow["QuizID"]"
                                                       class="btn btn-outline-primary btn-sm">
                                                        <i class="bi bi-pencil"></i>
                                                        Edit
                                                    </a>

                                                    <!-- Delete Button (POST with CSRF) -->
                                                    <form asp-controller="Quiz" asp-action="Delete" method="post" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this quiz?');">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="QuizID" value="@dataRow["QuizID"]" />
                                                        <button type="submit" class="btn btn-outline-danger btn-sm">
                                                            <i class="bi bi-x"></i> Delete
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                        </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </section>

    <script>
        document.addEventListener("keydown", function(event) {
            if (event.key === "F9") {
                event.preventDefault();
                let addQuizButton = document.getElementById("addQuiz");
                if (addQuizButton) {
                    addQuizButton.click();
                }
            }
        });
    </script>
</main>