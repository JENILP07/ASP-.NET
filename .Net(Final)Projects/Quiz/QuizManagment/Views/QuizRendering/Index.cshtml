@{
    ViewData["Title"] = "Available Quizzes";
}
<main id="main" class="main">
    <div class="pagetitle">
        <h1>Quiz Attempts</h1>
        <nav>
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Home</a></li>
                <li class="breadcrumb-item active">Quizzes</li>
            </ol>
        </nav>
    </div>

    <section class="section">
        <div class="row">
            <div class="card">
                <div class="card-body">
                    <h2 class="card-title">Available Tests</h2>

                    <!-- Quiz Table -->
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Quiz Name</th>
                                    <th>Total Questions</th>
                                    <th>Total Marks</th>
                                    <th>Status</th>
                                    <th>Passing Marks</th>
                                    <th>Scored Marks</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Mock Data Rows -->

                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </section>
</main>
