@model DataTable
@using System.Data
@{
    ViewData["Title"] = "Quiz Wise List";
}

<main id="main" class="main">
    <div class="pagetitle">
        <h1>Quiz Wise List</h1>
        <nav>
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home">Dashboard</a></li>
                <li class="breadcrumb-item active">Quiz Wise List</li>
            </ol>
        </nav>
    </div><!-- End Page Title -->

    <section class="section">
        <div class="row">
            <div class="card">
                <div class="card-body">
                    <h1 class="card-title"><i class="bx bx-search-alt"></i> Search Quiz Wise</h1>

                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start gap-3 mb-4">
                        <form method="get" class="flex-grow-1 w-100">
                            <div class="input-group">
                                <input type="search" class="form-control" placeholder="Search Quiz" name="searchTerm">
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-search"></i>
                                    <span class="d-none d-md-inline">Search</span>
                                </button>
                            </div>
                        </form>

                        <div class="mt-3 mt-md-0 w-100 w-md-auto">
                            <a asp-controller="QuizWise" asp-action="Form" class="btn btn-success w-100 w-md-40">
                                <i class="bi bi-plus-lg"></i>
                                <span class="d-none d-md-inline">Add Quiz (F9)</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-octagon me-1"></i>
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    <section class="section">
        <div class="row">
            <div class="card">
                <div class="card-body">
                    <h2 class="card-title">Quiz Wise List</h2>
                    @if (Model == null || Model.Rows.Count == 0)
                    {
                        <div class="alert alert-info">No users found.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table datatable">
                                <thead>
                                    <tr>
                                        <th>Quiz Wise ID</th>
                                        <th>Quiz Name</th>
                                        <th>Question Text</th>
                                        <th>Username</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (DataRow dataRow in Model.Rows)
                                    {
                                        <tr>
                                            <td>@dataRow["QuizWiseQuestionsID"]</td>
                                            <td>@dataRow["QuizName"]</td>
                                            <td>@dataRow["QuestionText"]</td>
                                            <td>@dataRow["UserName"]</td>
                                            <td>
                                                <div class="d-flex gap-1">
                                                    <!-- Edit Button -->
                                                    <a asp-controller="QuizWise" asp-action="QuizWiseQuestionAddEdit"
                                                       asp-route-QuizWiseQuestionsID="@dataRow["QuizWiseQuestionsID"]"
                                                       class="btn btn-outline-primary btn-sm">
                                                        <i class="bi bi-pencil"></i>
                                                        Edit
                                                    </a>

                                                    <!-- Delete Button -->
                                                    <a asp-controller="QuizWise" asp-action="Delete"
                                                       asp-route-QuizWiseQuestionsID="@dataRow["QuizWiseQuestionsID"]"
                                                       class="btn btn-outline-danger btn-sm"
                                                       onclick="return confirm('Are you sure you want to delete this user?');">
                                                        <i class="bi bi-x"></i>
                                                        Delete
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </section>
</main>

<script>
    document.addEventListener("keydown", function(event) {
        if (event.key === "F9") {
            event.preventDefault();
            let addQuizWiseButton = document.getElementById("addQuizWise");
            if (addQuizWiseButton) {
                addQuizWiseButton.click();
            }
        }
    });
</script>

