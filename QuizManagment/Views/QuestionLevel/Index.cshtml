@model DataTable
@using System.Data
@{
    ViewData["Title"] = "Question Level List";
}
<main id="main" class="main">
    <div class="pagetitle">
        <h1>Question Level List</h1>
        <nav>
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home">Dashboard</a></li>
                <li class="breadcrumb-item active">Question Level List</li>
            </ol>
        </nav>
    </div>

    <section class="section">
        <div class="row">
            <div class="card">
                <div class="card-body">
                    <h1 class="card-title"><i class="bx bx-search-alt"></i> Search Question Level</h1>

                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start gap-3 mb-4">
                        <form method="get" class="flex-grow-1 w-100">
                            <div class="input-group">
                                <input type="search" class="form-control" placeholder="Search Difficulty"
                                       aria-label="Search Difficulty" name="searchTerm">
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-search"></i>
                                    <span class="d-none d-md-inline">Search</span>
                                </button>
                                <button type="reset" class="btn btn-outline-secondary">
                                    <i class="bi bi-arrow-counterclockwise"></i>
                                    <span class="d-none d-md-inline">Reset</span>
                                </button>
                            </div>
                        </form>

                        <div class="mt-3 mt-md-0 w-100 w-md-auto">
                            <a asp-controller="QuestionLevel" asp-action="Form" class="btn btn-success w-100 w-md-40" id="addQuestionLevel">
                                <i class="bi bi-plus-lg"></i>
                                <span class="d-none d-md-inline">Add Question Level (F9)</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-octagon me-1"></i>
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-1"></i>
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <section class="section">
        <div class="row">
            <div class="card">
                <div class="card-body">
                    <div class="row">
                        <div class="col-6">
                            <h2 class="card-title">Question Level List</h2>
                        </div>
                        <div class="col-6 text-end mt-4">
                            <a asp-controller="QuestionLevel" asp-action="ExportToExcel" class="btn btn-outline-success">
                                <i class="bi bi-file-earmark-spreadsheet"></i> Export To Excel
                            </a>
                        </div>
                    </div>

                    @if (Model == null || Model.Rows.Count == 0)
                    {
                        <div class="alert alert-info">No question levels found.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table datatable table-hover ">
                                <thead>
                                    <tr class="text-center">
                                        <th>Question Level</th>
                                        <th>Username</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (DataRow dataRow in Model.Rows)
                                    {
                                        <tr>
                                            <td>@dataRow["QuestionLevel"]</td>
                                            <td>@dataRow["Username"]</td>
                                            <td>
                                                <div class="d-flex gap-2">
                                                    <!-- Edit Button -->
                                                    <a asp-controller="QuestionLevel" asp-action="Form"
                                                       asp-route-QuestionLevelID="@dataRow["QuestionLevelID"]"
                                                       class="btn btn-outline-primary btn-sm">
                                                        <i class="bi bi-pencil"></i>
                                                        Edit
                                                    </a>

                                                    <!-- Delete Button -->
                                                    <a asp-controller="QuestionLevel" asp-action="Delete"
                                                       asp-route-QuestionLevelID="@dataRow["QuestionLevelID"]"
                                                       class="btn btn-outline-danger btn-sm"
                                                       onclick="return confirm('Are you sure you want to delete this question level?');">
                                                        <i class="bi bi-x"></i>
                                                        Delete
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </section>
</main>

<script>
    document.addEventListener("keydown", function(event) {
        if (event.key === "F9") {
            event.preventDefault();
            let addQuestionLevelButton = document.getElementById("addQuestionLevel");
            if (addQuestionLevelButton) {
                addQuestionLevelButton.click();
            }
        }
    });
</script>
